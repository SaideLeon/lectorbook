# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# GitHub OAuth (Optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub token used by server-side requests (required to list user repositories).
# Configure only via .env on the server; do not provide token from the browser.
GITHUB_TOKEN=

# Groq API key (optional): used for speech-to-text features.
GROQ_API_KEY=

# Supabase (optional): enables persistent student data, chat history and vector search.
# URL: Project Settings -> API -> Project URL
SUPABASE_URL=

# Service role key: Project Settings -> API -> service_role
# Never expose this key in frontend code.
SUPABASE_SERVICE_ROLE_KEY=

# Publishable/anon key: pode ser usada quando não houver service role.
# Use no frontend e/ou como fallback no backend com permissões RLS adequadas.
SUPABASE_ANON_KEY=
